{
  "name": "migraine-tracker-monolith",
  "version": "1.0.0",
  "description": "",
  "author": "Vladimir Poplavskij<float45@gmail.com>",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"{src,test}/**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"{src,test}/**/*.{ts,js,json,md}\"",
    "start": "NODE_ENV=production nest start",
    "start:dev": "NODE_ENV=development nest start --watch",
    "start:debug": "NODE_ENV=development nest start --debug --watch",
    "start:prod": "NODE_ENV=production node dist/main",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:unit": "jest --testPathIgnorePatterns \".*\\\\.int\\\\.spec\\\\.ts$\" \".*integration\\\\.spec\\\\.ts$\"",
    "test:int-src": "jest --testRegex \".*(\\\\.int|integration)\\\\.spec\\\\.ts$\"",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integrations": "jest --config ./test/jest-integrations.json --runInBand",
    "test:docker": "USE_DOCKER=true jest",
    "knip": "knip -c ./knip.json",
    "check:updates": "ncu -i --format=group"
  },
  "languages": [
    {
      "id": "typescript",
      "extensions": [
        ".ts"
      ],
      "aliases": [
        "typescript",
        "TypeScript"
      ]
    }
  ],
  "keywords": [
    "nestjs",
    "api",
    "boilerplate",
    "swagger",
    "helmet",
    "cors",
    "health-check",
    "morgan",
    "prom-client",
    "migraine"
  ],
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@supabase/supabase-js": "^2.99.3",
    "@types/ms": "^2.1.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.13.6",
    "cache-manager": "^7.2.8",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "express": "^5.2.1",
    "haversine": "^1.1.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "mongodb": "^6.20.0",
    "mongoose": "^8.19.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "openmeteo": "^1.2.3",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.2",
    "@jest/types": "^30.3.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.15.18",
    "@types/express": "^5.0.6",
    "@types/haversine": "^1.1.8",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.7.1",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.18.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.4.0",
    "jest": "^29.7.0",
    "jest-mock": "^30.3.0",
    "knip": "^5.88.1",
    "mongodb-memory-server": "^10.2.3",
    "npm-check-updates": "^19.6.5",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverage": true,
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "watchPathIgnorePatterns": [
      "<rootDir>/src/public/"
    ],
    "globalSetup": "<rootDir>/../test/config/jest.global-setup.ts",
    "globalTeardown": "<rootDir>/../test/config/jest.global-teardown.ts",
    "setupFiles": [
      "<rootDir>/../test/config/jest.setup-env.ts"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}