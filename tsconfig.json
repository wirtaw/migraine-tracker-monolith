{
  "compilerOptions": {
    "module": "CommonJS",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "types": [
      "node",
      "jest"
    ],
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "strictBindCallApply": false,
    "noImplicitThis": true,
    "strict": true,
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "*.config.mjs"
, "prettier.config.mjs"  ],
  "exclude": [
    "node_modules",
    "dist",
    "prettier.config.mjs"
  ]
}
