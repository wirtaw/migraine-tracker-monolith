{
    "entry": [
    "src/main.ts",
    "src/**/*.module.ts"
  ],
  "project": [
    "src/**/*.ts"
  ],
  "ignore": [
    "src/**/*.spec.ts",
    "src/**/*.e2e-spec.ts",
    "src/migration/**/*.ts",
    "src/database/**/*.ts",
    "src/config/**/*.ts",
    "src/seed/**/*.ts"
  ],
  "ignoreBinaries": [],
  "ignoreDependencies": [
    "swagger-ui-express"
  ],
  "rules": {
    "files": "warn",
    "dependencies": "warn",
    "unlisted": "warn",
    "binaries": "warn",
    "exports": "warn",
    "types": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "classMembers": "warn",
    "enumMembers": "warn",
    "duplicates": "warn"
  }
  }